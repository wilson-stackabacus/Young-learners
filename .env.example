# Local dev: SQLite file (used when TURSO_DATABASE_URL is unset)
DATABASE_URL="file:./dev.db"

# Turso (production): set both to run on hosted libSQL instead of the local file.
# Create with:  turso db create questline  &&  turso db tokens create questline
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Gemini AI hints (optional). If unset, hints fall back to the built-in templated
# hints. Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"

# Firebase Auth — backend token verification (from your service-account JSON).
# If any are unset, the app falls back to the shared demo user.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Firebase Auth — public client config (browser login dialog). From the
# Firebase console → Project settings → your web app. Blank = guest/demo mode.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

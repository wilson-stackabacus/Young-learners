# Local dev: SQLite file (used when TURSO_DATABASE_URL is unset)
DATABASE_URL="file:./dev.db"

# Turso (production): set both to run on hosted libSQL instead of the local file.
# Create with:  turso db create questline  &&  turso db tokens create questline
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Gemini AI hints (optional). If unset, hints fall back to the built-in templated
# hints. Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"

// Prisma schema for Questline — level-ladder model.
// See docs/DESIGN.md, docs/API.md, and shared/contract.ts for the full spec.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // enables the libSQL/Turso adapter
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  displayName String
  createdAt   DateTime @default(now())
  role        String   @default("student") // "student" | "teacher"
  isGuest     Boolean  @default(false) // guests are excluded from leaderboards & purged on logout

  // Aggregate XP/streak (sum / latest across subjects) kept for the global
  // leaderboard + header backward-compat. Per-subject truth lives in SubjectProgress.
  totalXp      Int     @default(0)
  currentStage Int     @default(1) // legacy math pointer (engine now uses SubjectProgress)
  englishStage Int     @default(1001) // legacy english pointer

  currentStreak    Int     @default(0)
  longestStreak    Int     @default(0)
  lastActiveDay    String?
  freezesAvailable Int     @default(2)

  attempts        Attempt[]
  progress        LevelProgress[]
  subjectProgress SubjectProgress[]
  pending         PendingProblem[]
  badges          UserBadge[]
  quests          UserQuest[]

  // Classroom relationships
  classroomsCreated Classroom[]       @relation("TeacherClassrooms")
  classroomsJoined  ClassroomMember[]
}

// Static definition of one of the 225 stages. Seeded from lib/levelCatalog.
model Level {
  stage       Int     @id // math: 1..247, english: 1001..  — global level id
  subject     String  @default("math") // "math" | "english"
  tier        Int // difficulty step within the subject
  stageInTier Int // 1..5 for practice, 0 for a boss
  kind        String // "pure" | "blend" | "boss"
  skills      String // JSON array of skill ids, e.g. "[4,5]"
  world       String // biome id (shared with math for theming)
  difficulty  Float // 4 for pure Lv4, 4.5 for the Lv4½ blend
  isBoss      Boolean @default(false)
  testsLevel  Int? // boss only: the whole-level number it gates

  progress LevelProgress[]
}

// Per-user progress on a stage. The heart of the adaptive loop.
model LevelProgress {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  stage  Int
  level  Level  @relation(fields: [stage], references: [stage])

  status         String    @default("locked") // "locked" | "current" | "cleared"
  progress       Int       @default(0) // 0..100 progress bar (practice stages)
  stars          Int       @default(0) // 0..3
  totalCorrect   Int       @default(0)
  totalAttempts  Int       @default(0)
  recentResults  String    @default("[]") // JSON: rolling window of last 10 booleans
  clearedAt      DateTime?
  bossHp         Int? // boss only: HP remaining
  hearts         Int? // boss only: hearts remaining

  @@unique([userId, stage])
  @@index([userId])
}

// Per-user, per-subject state (the source of truth for XP/streak/stage). One
// row per (user, subject). Subject leaderboards rank by SubjectProgress.totalXp.
model SubjectProgress {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       String // "math" | "english" | "reading" | "science"
  currentStage  Int // the subject's reached stage (defaults to its first stage)
  totalXp       Int     @default(0)
  currentStreak Int     @default(0)
  longestStreak Int     @default(0)
  lastActiveDay String?
  placementDone Boolean @default(false) // placement test completed for this subject

  @@unique([userId, subject])
  @@index([userId])
}

// A generated, in-flight problem. Holds the answer server-side (never sent to
// the client) so submissions can be checked. One per active problem; deleted
// when the problem resolves.
model PendingProblem {
  token          String   @id
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  stage          Int
  prompt         String
  latex          String
  inputType      String // "numeric" | "fraction" | "multiple-choice"
  choices        String? // JSON, only for multiple-choice
  answer         String // the secret canonical answer
  hints          String // JSON array of strings
  solution       String
  commonMistakes String   @default("[]") // JSON: [{ value, hint }]
  attemptsUsed   Int      @default(0)
  isBoss         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId])
}

// One row per submitted answer. Drives accuracy + analytics.
model Attempt {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  stage           Int
  prompt          String
  givenAnswer     String?
  correct         Boolean
  hintsUsed       Int      @default(0)
  solvedAfterHint Boolean  @default(false)
  isBoss          Boolean  @default(false)
  xpAwarded       Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, stage])
}

model Badge {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  rule        String // JSON-encoded rule, evaluated by the badge engine
  tier        String @default("bronze")

  unlocks UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  badgeId    String
  badge      Badge    @relation(fields: [badgeId], references: [id])
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

model Classroom {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  teacherId String
  teacher   User     @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  members   ClassroomMember[]
}

model ClassroomMember {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@unique([classroomId, userId])
}

model Quest {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  type        String   // "problems_solved", "xp_earned", "streak_days", "correct_streak"
  targetValue Int
  xpReward    Int
  isActive    Boolean  @default(true)

  userQuests  UserQuest[]
}

model UserQuest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId     String
  quest       Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  @@unique([userId, questId])
}
